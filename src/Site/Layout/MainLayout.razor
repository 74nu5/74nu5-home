@inherits LayoutComponentBase
@implements IDisposable
@inject LocalizationService Loc
@inject ThemeService Theme

<header class="navbar">
    <div class="navbar__inner">
        <a class="brand" href="#top">
            <svg class="brand__mark" viewBox="0 0 64 64" width="26" height="26" aria-hidden="true">
                <rect x="2" y="2" width="60" height="60" rx="15" fill="#12161f" stroke="#2f3a55" stroke-width="2" />
                <polyline points="21,21 33,32 21,43" fill="none" stroke="#8b9dff" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round" />
                <rect x="36" y="38" width="15" height="5" rx="2.5" fill="#5eead4" />
            </svg>
            <span><span class="brand__accent">74</span>nu5<span class="brand__accent">.dev</span></span>
        </a>

        <nav class="nav-links @(_menuOpen ? "open" : "")" @onclick="CloseMenu">
            <a href="#apps"><span class="hash">#</span>@Loc["nav.apps"]</a>
            <a href="#projects"><span class="hash">#</span>@Loc["nav.projects"]</a>
            <a href="#stack"><span class="hash">#</span>@Loc["nav.stack"]</a>
            <a href="#contact"><span class="hash">#</span>@Loc["nav.contact"]</a>
        </nav>

        <div class="nav-tools">
            <LanguageToggle />
            <ThemeToggle />
            <button class="icon-btn nav-toggle" @onclick="ToggleMenu" aria-label="@Loc["a11y.menu"]">
                <Icon Name="menu" />
            </button>
        </div>
    </div>
</header>

<main id="top">
    @Body
</main>

<footer class="footer">
    <div class="container footer__inner">
        <span>© @DateTime.Now.Year @SiteContent.Name — @Loc["footer.built"]</span>
        <a href="@SiteContent.SiteRepoUrl" target="_blank" rel="noopener">@Loc["footer.source"] ↗</a>
    </div>
</footer>

@code {
    private bool _menuOpen;

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private void CloseMenu() => _menuOpen = false;

    protected override void OnInitialized()
    {
        Loc.OnChanged += Refresh;
        Theme.OnChanged += Refresh;
    }

    private void Refresh() => _ = InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Theme.InitializeAsync();
            await Loc.InitializeAsync();
        }
    }

    public void Dispose()
    {
        Loc.OnChanged -= Refresh;
        Theme.OnChanged -= Refresh;
    }
}
